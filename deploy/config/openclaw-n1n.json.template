{
  "meta": {
    "lastTouchedVersion": "2026.3.28",
    "lastTouchedAt": ""
  },
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "{{API_KEY}}",
    "ANTHROPIC_BASE_URL": "https://api.n1n.ai/apps/anthropic",
    "ANTHROPIC_MODEL": "gpt-4.1"
  },
  "wizard": {},
  "models": {
    "mode": "merge",
    "providers": {
      "openai": {
        "baseUrl": "https://api.n1n.ai/v1",
        "apiKey": "{{API_KEY}}",
        "api": "openai-completions",
        "models": [
          {
            "id": "gpt-4.1",
            "name": "GPT-4.1",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
            "contextWindow": 200000,
            "maxTokens": 32000
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-4.1"
      },
      "models": {
        "openai/gpt-4.1": {}
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "commands": {
    "native": true,
    "nativeSkills": true,
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "openclaw-weixin": {
      "accounts": {}
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "{{GATEWAY_TOKEN}}"
    }
  },
  "plugins": {
    "allow": [
      "openclaw-weixin"
    ],
    "load": {
      "paths": []
    },
    "slots": {},
    "entries": {
      "openclaw-weixin": {
        "enabled": true,
        "config": {}
      }
    }
  }
}